{
  "expo": {
    "name": "Cricket Scorer Pro",
    "slug": "cricket-scorer-pro",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4D3E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1.2.0"
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1B4D3E"
      },
      "package": "com.gokulakrishnan.cricketscorerpro"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "bfd3244b-bd25-4466-b031-d27f9afcebe4"
      }
    }
  }
}